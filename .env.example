GEMINI_API_KEY=
BRIDGE_PORT=3001
AGENT_PORT=3000

# Telegram bot token from @BotFather (/newbot). Hearth talks directly to the
# Telegram Bot API via long-polling — no Photon cloud needed.
TELEGRAM_BOT_TOKEN=
# Telegram group chat id — Hearth replies here. Run
# `npm run setup -w packages/bridge` to discover and save it.
TARGET_CHAT_GUID=

# Where proactive nags are delivered (defaults to the bridge above).
NAG_BRIDGE_PORT=
NAG_CHAT_ID=

# ── Browserbase (Phase 8 grocery orders + utility monitor) ────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Persistent context created once via Browserbase dashboard. Login state for
# grocery and utility sites lives here — never store credentials in env/code.
BROWSERBASE_CONTEXT_ID=

# ── Grocery ordering ──────────────────────────────────────────────────────────
GROCERY_STORE_URL=https://www.instacart.com
# Hard spending ceiling — agent refuses to check out above this amount.
MAX_ORDER_TOTAL=150
# true = build cart + screenshot but NEVER place the order. Keep on until verified end-to-end.
ORDER_DRY_RUN=true

# ── Utility autopay ───────────────────────────────────────────────────────────
# Hard guard — autopay never fires when false, regardless of per-account setting.
UTILITY_AUTOPAY=false

# ── Landlord messaging ────────────────────────────────────────────────────────
# When false, landlord messages are shown in chat for manual sending only.
LANDLORD_MESSAGE_ENABLED=false

# ── Move mode ─────────────────────────────────────────────────────────────────
# When false, utility transfer browser jobs are skipped; Hearth posts manual steps.
MOVE_UTILITY_TRANSFERS_ENABLED=false
