GEMINI_API_KEY=
BRIDGE_PORT=3001
AGENT_PORT=3000

# ── Nebius AI Studio (REQUIRED — all inference runs through this) ────────────
NEBIUS_API_KEY=
NEBIUS_ORCHESTRATOR_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507
NEBIUS_FAST_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
NEBIUS_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct
# Client-side rate limit for Nebius requests (default 60).
NEBIUS_RPM=60

# Telegram bot token from @BotFather (/newbot). Hearth talks directly to the
# Telegram Bot API via long-polling — no Photon cloud needed.
TELEGRAM_BOT_TOKEN=
# Telegram group chat id — Hearth replies here. Run
# `npm run setup -w packages/bridge` to discover and save it.
TARGET_CHAT_GUID=

# Where proactive nags are delivered (defaults to the bridge above).
NAG_BRIDGE_PORT=
NAG_CHAT_ID=

# ── Browserbase (Phase 8 grocery orders + utility monitor) ────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Persistent context created once via Browserbase dashboard. Login state for
# grocery and utility sites lives here — never store credentials in env/code.
BROWSERBASE_CONTEXT_ID=

# ── Grocery ordering ──────────────────────────────────────────────────────────
GROCERY_STORE_URL=https://www.instacart.com
# Hard spending ceiling — agent refuses to check out above this amount.
MAX_ORDER_TOTAL=150
# true = build cart + screenshot but NEVER place the order. Keep on until verified end-to-end.
ORDER_DRY_RUN=true

# ── Utility autopay ───────────────────────────────────────────────────────────
# Hard guard — autopay never fires when false, regardless of per-account setting.
UTILITY_AUTOPAY=false

# ── Landlord messaging ────────────────────────────────────────────────────────
# When false, landlord messages are shown in chat for manual sending only.
LANDLORD_MESSAGE_ENABLED=false

# ── Move mode ─────────────────────────────────────────────────────────────────
# When false, utility transfer browser jobs are skipped; Hearth posts manual steps.
MOVE_UTILITY_TRANSFERS_ENABLED=false

# ── Demo mode ─────────────────────────────────────────────────────────────────
# true (default) = fully SIMULATE unconnected integrations (bill pay, phone calls,
# grocery ordering, utility checks) with convincing confirmations and real ledger
# updates — no external services called, and no "dry run" tells in the output.
# Set to false only once Browserbase/Vapi/etc. are actually wired up.
DEMO_MODE=true
# How long a simulated phone call appears to take before the outcome lands (ms).
DEMO_CALL_MS=6000

# ── Bill pay (pay_bill tool) ──────────────────────────────────────────────────
# true = fill in the payment form + stop at a screenshot, but NEVER submit even
# after approval. Keep on until verified end-to-end. Portal URLs come from
# registered utility accounts or facts like `<biller>_portal` / `<biller>_account`.
BILLPAY_DRY_RUN=true

# ── Vapi (call_vendor tool) ───────────────────────────────────────────────────
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# Optional voice override for the outbound assistant.
VAPI_VOICE_ID=Elliot

# ── InsForge (agent-native backend, optional) ────────────────────────────────
# When both are set, Kin uses InsForge (Postgres + storage) as its state backend
# instead of Butterbase, and stores receipt images in the bucket below. Run
# `npm run provision -w packages/agent` once to create tables + bucket. When
# unset, falls back to Butterbase, then in-memory state.
INSFORGE_URL=
INSFORGE_API_KEY=
INSFORGE_STORAGE_BUCKET=receipts

# ── You.com (web_search, optional — takes precedence over Perplexity) ─────────
# Citation-backed search. YOU_SEARCH_ENDPOINT picks the default endpoint family;
# callers may override per-call (vendor lookups use `deep`).
YOU_API_KEY=
YOU_SEARCH_ENDPOINT=web        # web | news | research | deep

# ── Nimble (live product/grocery pricing, optional) ───────────────────────────
# Powers the compare_prices tool and cheapest-store grocery hints. When unset (or
# in DEMO_MODE), returns a realistic simulated price set so demos run offline.
NIMBLE_API_KEY=

# ── Hydra DB (spending analytics, optional) ───────────────────────────────────
# Direct Postgres/Hydra connection for ledger aggregation. When unset or
# unavailable, spending_report computes from the normal ledger API.
HYDRA_DATABASE_URL=

# ── GTM marketing employee (Nimble + Kylon, optional) ────────────────────────
# A separate scheduled agent that asks the main agent for a Nimble trend + Kin
# marketing draft, then creates a Kylon draft for human review. It exits cleanly
# when KYLON_API_KEY / KYLON_WORKSPACE_ID are unset.
KYLON_API_KEY=
KYLON_WORKSPACE_ID=
GTM_AGENT_PORT=3003
GTM_INTERVAL_MS=86400000
GTM_AUTOPOST=false
# Product to mine for the recurring trend.
GTM_TREND_PRODUCT=eggs
# Optional Kylon routing. Set KYLON_CHANNEL_ID to post drafts via Kylon CLI, or
# set KYLON_DRAFT_TOOL to a Kylon Tools API tool slug that creates a draft/task.
KYLON_CHANNEL_ID=
KYLON_DRAFT_TOOL=
KYLON_DRAFT_CONNECTION_ID=
# X publishing through Kylon Tools API. Only used when GTM_AUTOPOST=true and
# DEMO_MODE=false.
KYLON_X_TOOL=X_CREATE_POST
KYLON_X_CONNECTION_ID=

# ── Butterbase (fallback state backend, optional) ─────────────────────────────
# Used when InsForge is unset. When neither is set, state is in-memory only.
BUTTERBASE_APP_ID=
BUTTERBASE_API_KEY=

# ── Slack bridge (optional alternate frontend) ────────────────────────────────
# The Slack bridge exits cleanly when these are unset.
SLACK_JWT=
SLACK_TEAM_ID=
TARGET_SLACK_CHANNEL=
SLACK_BRIDGE_PORT=3002

# ── Perplexity (web_search fallback, optional) ────────────────────────────────
# Used only when YOU_API_KEY is unset. When neither is set, web_search falls back
# to an ungrounded Nebius completion (no sources).
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar
